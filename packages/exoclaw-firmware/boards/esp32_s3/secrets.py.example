# Copy to ``secrets.py`` (sibling of this file) and fill in.
# ``secrets.py`` is gitignored — never check in real values.
#
# The ESP32-S3's flash filesystem is the staging ground:
# ``mise run flash`` copies this file (and the rest of the
# ``boards/esp32_s3/`` tree) onto the device. Boot reads
# ``/secrets.py``.

# ── WiFi ──────────────────────────────────────────────────────
WIFI_SSID = "your-network"
WIFI_PASSWORD = "your-password"

# ── LLM provider ──────────────────────────────────────────────
OPENAI_API_KEY = "sk-..."
# Override for OpenAI-compatible endpoints (Groq, OpenRouter,
# local llama.cpp). Leave commented for the real OpenAI API.
# OPENAI_BASE_URL = "https://api.groq.com/openai/v1"
# OPENAI_MODEL = "llama-3.1-70b-versatile"

# ── Storage ──────────────────────────────────────────────────
# Where the conversation package writes sessions / memory / skills.
# Default points at the SD card mounted in boot.py. If you don't
# have an SD card wired up, point this at flash (e.g. "/exoclaw")
# but be aware flash wears out under heavy JSONL appends.
WORKSPACE = "/sd/exoclaw"
